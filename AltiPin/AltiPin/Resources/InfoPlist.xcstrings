        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TopoLog necesita acceso a Fotos para guardar el contenido capturado."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TopoLog a besoin d'accéder à Photos pour enregistrer le contenu capturé."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TopoLog को कैप्चर सामग्री सहेजने के लिए फ़ोटो लाइब्रेरी एक्सेस चाहिए।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TopoLogは撮影内容を写真に保存するためにライブラリへのアクセスが必要です。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TopoLog precisa de acesso às Fotos para salvar conteúdo capturado."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TopoLog 需要相册写入权限以保存拍摄内容到系统相册。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TopoLog 需要相簿寫入權限以儲存拍攝內容到系統相簿。"
          }
