    "NSMicrophoneUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يحتاج TopoLog إلى الميكروفون لتسجيل فيديوهات بعلامة مائية جغرافية."
