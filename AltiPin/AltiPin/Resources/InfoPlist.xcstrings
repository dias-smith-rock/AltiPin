    "NSCameraUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يحتاج TopoLog إلى الوصول إلى الكاميرا لالتقاط صور وفيديوهات بعلامة مائية جغرافية."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TopoLog needs camera access to capture photos and videos with geo stamps."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TopoLog necesita acceso a la cámara para capturar fotos y videos con marcas geográficas."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TopoLog a besoin de l'appareil photo pour capturer des photos et vidéos avec tampon géo."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TopoLog को जियो स्टैम्प वाली फ़ोटो और वीडियो के लिए कैमरा एक्सेस चाहिए।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TopoLogは位置情報スタンプ付きの写真・動画撮影のためにカメラへのアクセスが必要です。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TopoLog precisa de acesso à câmera para capturar fotos e vídeos com carimbo geográfico."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TopoLog 需要相机权限以拍摄带经纬度水印的照片与视频。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TopoLog 需要相機權限以拍攝帶經緯度浮水印的照片與影片。"
          }
        }
      }
    },
    "NSLocationAlwaysAndWhenInUseUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يحتاج TopoLog إلى موقعك في الخلفية لتسجيل المسارات والارتفاع."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TopoLog needs your location in the background to record tracks and elevation."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TopoLog necesita tu ubicación en segundo plano para registrar rutas y altitud."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TopoLog a besoin de votre position en arrière-plan pour enregistrer traces et altitude."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TopoLog को ट्रैक और ऊंचाई रिकॉर्ड करने के लिए पृष्ठभूमि में स्थान चाहिए।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TopoLogは軌跡と標高を記録するためにバックグラウンドでの位置情報が必要です。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TopoLog precisa da sua localização em segundo plano para registrar trilhas e altitude."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TopoLog 需要在后台记录您的徒步、骑行轨迹与海拔。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TopoLog 需要在背景記錄您的徒步、騎行軌跡與海拔。"
          }
        }
      }
    },
