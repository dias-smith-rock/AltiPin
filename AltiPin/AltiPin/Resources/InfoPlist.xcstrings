        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TopoLog को जियो स्टैम्प वाले वीडियो के लिए माइक्रोफ़ोन चाहिए।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TopoLogは位置情報スタンプ付き動画録画のためにマイクへのアクセスが必要です。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TopoLog precisa de acesso ao microfone para gravar vídeos com carimbo geográfico."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TopoLog 需要麦克风权限以录制带地理信息水印的视频。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TopoLog 需要麥克風權限以錄製帶地理資訊浮水印的影片。"
          }
        }
