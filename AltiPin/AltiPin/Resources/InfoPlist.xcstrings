    },
    "NSMotionUsageDescription" : {
      "extractionState" : "manual",
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يستخدم TopoLog حالة الحركة للبدء/الإيقاف التلقائي للتسجيل لتوفير البطارية."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TopoLog uses motion activity to auto start/stop recording and save battery."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TopoLog usa la actividad de movimiento para iniciar/detener la grabación automáticamente."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TopoLog utilise l'activité de mouvement pour démarrer/arrêter l'enregistrement automatiquement."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TopoLog बैटरी बचाने के लिए गति से ऑटो रिकॉर्डिंग शुरू/रोकता है।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TopoLogは省電力のためモーション状態で記録を自動開始/停止します。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TopoLog usa atividade de movimento para iniciar/parar gravação automaticamente."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TopoLog 通过运动状态识别自动开始/停止记录，以节省电量。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "TopoLog 透過運動狀態識別自動開始/停止記錄，以節省電量。"
          }
        }
      }
    },
    "NSPhotoLibraryAddUsageDescription" : {
      "extractionState" : "manual",
