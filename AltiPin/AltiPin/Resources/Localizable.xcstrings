    "After leaving, the host role passes to the next member." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "بعد المغادرة، ينتقل الدور للعضو التالي."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "After leaving, the host role passes to the next member."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Al salir, el anfitrión pasa al siguiente miembro."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En quittant, l'hôte passe au membre suivant."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "छोड़ने पर होस्ट अगले सदस्य को मिलेगा।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "退出後、ホストは次のメンバーに移ります。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ao sair, o anfitrião passa ao próximo membro."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "退出后房主将自动移交给下一位队员，其余成员可继续组队。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "退出後房主將自動移交給下一位隊員，其餘成員可繼續組隊。"
          }
